# OpenAI API Key for AI chapter generation
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Firebase Configuration
# These are auto-generated by `flutterfire configure`
# Only needed if not using flutterfire CLI
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_AUTH_DOMAIN=
