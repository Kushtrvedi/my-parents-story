{
  "buildCommand": "bash build.sh",
  "outputDirectory": "build/vercel_output",
  "rewrites": [
    {
      "source": "/myparents/(.*)",
      "destination": "/myparents/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/myparents/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
